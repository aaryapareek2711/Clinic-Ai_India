# Copy to `.env` and restart `npm run dev` after changes.
# Keep empty in local dev to use Vite proxy (recommended):
# VITE_API_BASE_URL=
# Set this only when targeting a non-local backend:
# VITE_API_BASE_URL=https://your-backend.example.com
# Optional. Used for GET /api/visits/provider/{id} on the Visits list. Backend still returns visits with no provider_id.
# VITE_PROVIDER_ID=default
